# ctxpack evaluation API keys
# Copy this file to .env and fill in your key(s).
# Only one provider is needed for fidelity testing.

# Anthropic API key (for Claude models — recommended)
ANTHROPIC_API_KEY=

# OpenAI API key (for GPT models — alternative)
OPENAI_API_KEY=

# Which provider to use for fidelity eval: "anthropic" or "openai"
CTXPACK_EVAL_PROVIDER=anthropic

# Which model to use (defaults shown below)
# Anthropic: claude-sonnet-4-6
# OpenAI: gpt-4o
CTXPACK_EVAL_MODEL=
